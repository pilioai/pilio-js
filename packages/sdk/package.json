{
  "name": "@pilio/sdk",
  "version": "0.2.0",
  "description": "Official JavaScript and TypeScript SDK for the Pilio public API.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pilioai/pilio-js.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["pilio", "sdk", "gpt-image-2", "nano-banana-2", "image-api"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}
