{
  "name": "pilio-js",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm --filter @pilio/sdk build && pnpm -r typecheck",
    "smoke:cli": "node scripts/smoke-cli.mjs",
    "generate:types": "openapi-typescript openapi/pilio-openapi.json --output packages/sdk/src/generated/openapi.d.ts",
    "lint:openapi": "redocly lint openapi/pilio-openapi.json",
    "sync:openapi": "node scripts/sync-openapi.mjs"
  },
  "devDependencies": {
    "@redocly/cli": "^2.12.0",
    "@types/node": "^24.0.0",
    "openapi-typescript": "^7.13.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}
